{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "registrationId": {
      "type": "string",
      "description": "Unique government-issued registration identifier"
    },
    "tagId": {
      "type": "string",
      "description": "Physical ear tag or RFID tag number on the animal"
    },
    "name": {
      "type": "string",
      "description": "Common name or farm-given name of the animal"
    },
    "species": {
      "type": "string",
      "enum": ["cattle", "goat", "sheep", "pig", "poultry", "horse", "other"],
      "description": "Type of livestock"
    },
    "breed": {
      "type": "string",
      "description": "Breed of the animal"
    },
    "gender": {
      "type": "string",
      "enum": ["male", "female", "castrated_male"],
      "description": "Sex of the animal"
    },
    "dateOfBirth": {
      "type": "string",
      "format": "date",
      "description": "Date of birth in YYYY-MM-DD format"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deceased", "sold", "slaughtered", "exported"],
      "description": "Current compliance status of the animal"
    },
    "ownerId": {
      "type": "string",
      "description": "Government ID or registration number of the current owner"
    },
    "ownerName": {
      "type": "string",
      "description": "Full name of the current owner"
    },
    "farmId": {
      "type": "string",
      "description": "Registered farm or premises identifier"
    },
    "farmLocation": {
      "type": "object",
      "properties": {
        "state": { "type": "string" },
        "district": { "type": "string" },
        "village": { "type": "string" },
        "pincode": { "type": "string" }
      },
      "required": ["state", "district"]
    },
    "vaccinations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "vaccineName": { "type": "string" },
          "administeredOn": { "type": "string", "format": "date" },
          "nextDueOn": { "type": "string", "format": "date" },
          "administeredBy": { "type": "string" }
        },
        "required": ["vaccineName", "administeredOn"]
      },
      "description": "Vaccination history for compliance"
    },
    "originCountry": {
      "type": "string",
      "description": "Country of origin, especially for imported livestock"
    },
    "importPermitId": {
      "type": "string",
      "description": "Permit ID if the animal was imported"
    },
    "registeredOn": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the animal was registered in the system"
    },
    "updatedOn": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of the last record update"
    },
    "remarks": {
      "type": "string",
      "maxLength": 1000,
      "description": "Additional compliance notes or officer remarks"
    }
  },
  "required": [
    "registrationId",
    "tagId",
    "species",
    "gender",
    "status",
    "ownerId",
    "ownerName",
    "farmId",
    "farmLocation",
    "registeredOn"
  ]
}