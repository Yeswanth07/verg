{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "cropId": {
      "type": "string"
    },
    "farmerId": {
      "type": "string"
    },
    "farmId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 5,
      "maxLength": 500
    },
    "category": {
      "type": "string"
    },
    "season": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    },
    "sownAreaHectares": {
      "type": "number"
    },
    "sourceName": {
      "type": "string"
    },
    "channel": {
      "type": "string"
    },
    "surveyMethod": {
      "type": "string"
    },
    "imgUrl": {
      "type": "string",
      "format": "uri"
    },
    "createdFor": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "createdOn": {
      "type": "string"
    },
    "updatedOn": {
      "type": "string"
    },
    "expiredOn": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "cropId",
    "farmerId",
    "farmId",
    "name",
    "season",
    "year",
    "sownAreaHectares"
  ]
}
